{
  "name": "roshan-dhungana/status",
  "description": "Reusable enum helpers for status handling (values, options, labels) with Laravel support",
  "type": "library",
  "license": "MIT",

  "authors": [
    {
      "name": "Roshan Dhungana",
      "email": "dhunganaroshan341@gmail.com"
    }
  ],

  "require": {
    "php": "^8.1",
    "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
  },

  "autoload": {
    "psr-4": {
      "RoshanDhungana\\Status\\": "src/"
    }
  },

  "extra": {
    "laravel": {
      "providers": [
        "RoshanDhungana\\Status\\StatusServiceProvider"
      ]
    }
  },

  "minimum-stability": "stable",
  "prefer-stable": true
}